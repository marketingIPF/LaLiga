rules_version = '2';

// ============================================================
// La Liga · Reglas de seguridad Firestore
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- HELPERS --------
    function isSignedIn() {
      return request.auth != null;
    }

    function myUid() {
      return request.auth.uid;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(myUid())).data;
    }

    function profileExists() {
      return exists(/databases/$(database)/documents/users/$(myUid()));
    }

    function isAdmin() {
      return isSignedIn()
        && profileExists()
        && myProfile().role == 'Codirector';
    }

    // El propio agente nunca puede modificar campos económicos
    function economicFieldsUnchanged() {
      return request.resource.data.points == resource.data.points
        && request.resource.data.lifetimePoints == resource.data.lifetimePoints
        && request.resource.data.get('periodBilling', 0) == resource.data.get('periodBilling', 0)
        && request.resource.data.get('totalBilling', 0) == resource.data.get('totalBilling', 0);
    }

    function roleAndGroupUnchanged() {
      return request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
        && request.resource.data.groupId == resource.data.groupId;
    }

    // -------- USERS --------
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isSignedIn()
          && myUid() == userId
          && economicFieldsUnchanged()
          && roleAndGroupUnchanged()
        );
    }

    // -------- GROUPS --------
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // -------- ACTION REQUESTS --------
    match /actionRequests/{reqId} {
      allow read: if isSignedIn();
      allow create: if
        // Usuarios: registran sus propias solicitudes (pendientes)
        (isSignedIn()
          && profileExists()
          && request.resource.data.userId == myUid()
          && request.resource.data.status == 'pending'
          && request.resource.data.reviewedBy == null
          && request.resource.data.points is int
          && request.resource.data.points > 0
          && request.resource.data.points <= 200)
        // Admins: carga masiva y correcciones desde el panel (aprobadas,
        // para cualquier usuario). Se permiten puntos negativos para restar,
        // dentro de un rango razonable.
        || (isAdmin()
          && request.resource.data.status == 'approved'
          && request.resource.data.reviewedBy == myUid()
          && request.resource.data.points is int
          && request.resource.data.points >= -10000
          && request.resource.data.points <= 10000
          && request.resource.data.points != 0);
      allow update: if isAdmin()
        && resource.data.status == 'pending'
        && request.resource.data.status in ['approved', 'rejected']
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.points == resource.data.points;
      allow delete: if isAdmin();
    }

    // -------- BILLING REQUESTS --------
    match /billingRequests/{reqId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && profileExists()
        && request.resource.data.userId == myUid()
        && request.resource.data.status == 'pending'
        && request.resource.data.reviewedBy == null
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 1000000;
      allow update: if isAdmin()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.amount == resource.data.amount
        && (
          // Aprobar / rechazar una pendiente
          (resource.data.status == 'pending'
            && request.resource.data.status in ['approved', 'rejected'])
          // Editar el multiplicador de una ya aprobada
          || (resource.data.status == 'approved'
            && request.resource.data.status == 'approved')
        );
      allow delete: if isAdmin();
    }

    // -------- ACHIEVEMENTS --------
    match /achievements/{achId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // -------- NOTIFICATIONS --------
    // Cada notificación tiene un userId destinatario. Solo el destinatario
    // puede leerla. Cualquiera autenticado puede crearlas (necesario para
    // que un agente notifique a admins y viceversa). Solo el destinatario
    // puede marcarla como leída.
    match /notifications/{notifId} {
      allow read: if isSignedIn()
        && (resource.data.userId == myUid() || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId is string
        && request.resource.data.type is string
        && request.resource.data.title is string
        && request.resource.data.read == false;
      allow update: if isSignedIn()
        && resource.data.userId == myUid()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.type == resource.data.type
        && request.resource.data.title == resource.data.title
        && request.resource.data.message == resource.data.message;
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == myUid());
    }
  }
}
